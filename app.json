{
  "expo": {
    "name": "萌宠星球",
    "slug": "pet-planet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "petplanet",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.petplanet.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F0F7F4",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.petplanet.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "允许萌宠星球访问你的照片，用于发布帖子和上传头像。",
          "cameraPermission": "允许萌宠星球使用相机，用于拍摄并上传宠物照片。"
        }
      ],
      "expo-audio"
    ]
  }
}
