{
  "name": "pet-planet",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/metro-runtime": "^56.0.13",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-preset-expo": "^56.0.13",
    "expo": "~56.0.5",
    "expo-audio": "~56.0.11",
    "expo-constants": "~56.0.16",
    "expo-image-picker": "^56.0.14",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.12",
    "expo-router": "~56.2.7",
    "expo-secure-store": "~56.0.4",
    "expo-speech": "~56.0.3",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "server": "npm --prefix server start",
    "server:dev": "npm --prefix server run dev",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit --pretty false",
    "test:server:smoke": "node server/test-api.js",
    "test:product": "npm run typecheck && npm run test:server:smoke",
    "test:ui:smoke": "node scripts/product-ui-smoke.js",
    "db:summary": "node scripts/db-summary.js",
    "db:cleanup:dry-run": "node scripts/cleanup-test-data.js",
    "db:cleanup": "node scripts/cleanup-test-data.js --apply",
    "verify": "npm run typecheck && npm run db:summary && npm run test:server:smoke"
  },
  "private": true
}
