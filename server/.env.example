# Runtime
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://petplanet.example.com

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=pet_planet_user
DB_PASSWORD=change_me
DB_NAME=pet_planet

# Auth
JWT_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=./uploads

# AI
DEEPSEEK_API_KEY=replace_with_deepseek_key
